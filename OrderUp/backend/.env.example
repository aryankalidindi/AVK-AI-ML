# Required
AUTH_TOKEN=change-me-to-a-long-random-string

# LLM provider: 'gemini' (free tier at aistudio.google.com) or 'anthropic'
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza...
#GEMINI_MODEL=gemini-2.5-flash

# Only needed when LLM_PROVIDER=anthropic
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-opus-4-8

# Optional (defaults shown)
PORT=4741
BIND_HOST=127.0.0.1
CONFIDENCE_THRESHOLD=0.8
MAX_ORDER_CENTS=5000
DRY_RUN=true
NTFY_URL=http://127.0.0.1:8090
NTFY_TOPIC=orderup
USER_DATA_DIR=./.chromium-profile
SCREENSHOT_DIR=./screenshots
DATA_FILE=./orders.json
EXPIRY_MINUTES=10
HEADLESS=false
