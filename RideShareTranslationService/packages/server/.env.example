# Server (dispatch WS + /translate). Copy to .env or export before `npm run dev:server`.

# Enable context-aware Claude translation (natural, colloquial, uses recent
# conversation for context). WITHOUT this key the server makes NO external API
# call and clients use the free browser translator (gtx) as a fallback.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model. Default is claude-haiku-4-5 for low latency on
# live chat. Use a larger model (e.g. claude-opus-4-8) for the best quality.
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: HTTP/WS port (default 8787).
# PORT=8787
